# Copy to .env for local overrides (optional)
POSTGRES_DB=ai_receptionist
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Host ports
FRONTEND_PORT=8080
BACKEND_PORT=8000
DB_PORT=5432

# Backend configuration
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/ai_receptionist
CORS_ALLOW_ORIGINS=*
LOG_LEVEL=INFO

# Hosted LLM — put your real key in .env only (never commit .env)
LLM_ENABLED=false
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash
API_KEY=
# Legacy aliases also supported: LLM_API_KEY, GEMINI_API_KEY, OPENAI_API_KEY
LLM_TIMEOUT_SECONDS=15
LLM_MAX_HISTORY_MESSAGES=20
